@echo off
chcp 65001 >nul
title GitHub Auto-Update

echo ==========================================
echo 🌐 Проверка обновлений на сервере GitHub...
echo ==========================================
git pull origin main

echo.
echo ==========================================
echo 📦 Индексация измененных файлов...
echo ==========================================
git add .

:: Формируем автоматическое сообщение коммита с текущей датой и временем
set commit_msg=Auto-update: %date% %time%

echo.
echo ==========================================
echo 💾 Фиксация изменений (Commit)...
echo ==========================================
git commit -m "%commit_msg%"

echo.
echo ==========================================
echo 🚀 Отправка файлов на GitHub...
echo ==========================================
git push origin main

echo.
echo ==========================================
echo ✅ Все файлы успешно обновлены на гитхабе!
echo ==========================================
timeout /t 5
exit